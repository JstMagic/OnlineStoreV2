{
  "name": "onlinestorev2",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "type-check": "tsc --noEmit && eslint .",
    "test": "vitest run --passWithNoTests",
    "verify": "npm install --no-audit --no-fund --include=dev --loglevel=error && tsc --noEmit && eslint . && vitest run --passWithNoTests && node scripts/smoke.mjs",
    "start": "node dist/main.js",
    "dev": "tsx watch src/main.ts",
    "lint": "eslint ."
  },
  "dependencies": {
    "@nestjs/common": "^10.4.4",
    "@nestjs/core": "^10.4.4",
    "@nestjs/platform-express": "^10.4.4",
    "@nestjs/config": "^3.2.3",
    "@nestjs/throttler": "^6.2.1",
    "class-validator": "^0.14.1",
    "class-transformer": "^0.5.1",
    "helmet": "^7.1.0",
    "zod": "^3.23.8",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "pg": "^8.12.0"
  },
  "devDependencies": {
    "typescript": "^5.5.4",
    "tsx": "^4.19.2",
    "vitest": "^2.0.5",
    "@types/node": "^20.14.0",
    "@types/express": "^4.17.21",
    "eslint": "^9.9.0",
    "@typescript-eslint/parser": "^8.3.0",
    "@typescript-eslint/eslint-plugin": "^8.3.0",
    "@types/pg": "^8.11.6"
  }
}
